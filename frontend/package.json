{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "katex": "^0.16.9",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.6",
    "pixel-retroui": "^2.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-katex": "^3.0.1",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.2"
  },
  "scripts": {
    "build:css": "tailwindcss -i src/index.css -o src/compiled.css && node -e \"const f=require('fs');f.writeFileSync('src/compiled.css',f.readFileSync('src/compiled.css','utf8').replace(/infinity/g,'99999'))\"",
    "start": "npm run build:css && react-scripts start",
    "build": "CI=false npm run build:css && CI=false GENERATE_SOURCEMAP=false NODE_OPTIONS=--max_old_space_size=4096 react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1"
  }
}
